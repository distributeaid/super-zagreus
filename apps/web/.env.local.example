# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.
# See docs/local-development.md for a full walkthrough.

# Base URL of the running DA.NA.Api backend.
# Must match the port the API actually binds — see apps/api/DA.NA.Api/Properties/launchSettings.json.
# (Use the plain-HTTP port; the https port uses a self-signed cert that server-side fetch rejects.)
API_BASE_URL=http://localhost:54764

# Auth.js session secret. Required — without it you get a MissingSecret error.
# Generate with: openssl rand -base64 33
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → Credentials → OAuth client, Web application).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra ID app registration (Entra admin center → App registrations).
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
